# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Google Sheet ID (from URL)
# Example URL: https://docs.google.com/spreadsheets/d/1ABC123xyz.../edit
# Sheet ID is: 1ABC123xyz...
SHEET_ID=your_google_sheet_id_here

# Sheet names (can use defaults)
SHEET_PRODUCTS=Products
SHEET_SALES=Sales
SHEET_EXPENSES=Expenses

# Admin IDs (optional, comma separated)
# ADMIN_IDS=123456789,987654321

# Bảo mật: Chỉ cho phép user ID này sử dụng bot (optional)
# Lấy ID bằng cách chat với @userinfobot trên Telegram
# ALLOWED_USER_ID=your_telegram_user_id

# PayOS credentials (lấy từ https://my.payos.vn > Channel > Settings)
PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here
